              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["user"]
            },
            "description": "Update user email and password."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Basic dGVzdHVzZXI6cGFzc3dvcmQxMjM="
              }
            ],
            "url": {
              "raw": "http://localhost:8080/user/testuser",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["user", "testuser"]
            },
            "description": "Delete user account completely."
          },
          "response": []
        }
      ]
    },
